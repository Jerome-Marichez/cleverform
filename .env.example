# Modèle de configuration — voir docs/architecture.md et docs/data-model.md.
#
# Deux fichiers locaux (tous deux gitignorés) :
#   - .env.local : variables de la base Neon, gérées par Vercel.
#                  Récupérées via `make db-pull` (= `vercel env pull .env.local`).
#   - .env       : secrets applicatifs NON gérés par Vercel (ci-dessous).
#
# Prisma (prisma.config.ts) et Next.js chargent les deux ; .env.local a priorité.

# --- Base de données PostgreSQL (Neon) — normalement fournies dans .env.local ---
# URL POOLÉE (hôte « ...-pooler... ») → runtime serverless, lue par le driver adapter Prisma.
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
# URL DIRECTE (sans « -pooler ») → migrations Prisma (CLI). Neon la nomme DATABASE_URL_UNPOOLED ;
# en local/docker on peut aussi définir DIRECT_URL (prioritaire si présent).
DATABASE_URL_UNPOOLED="postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"

# --- Secrets applicatifs (à mettre dans .env) ---
# IA — clé API Claude (serveur uniquement, jamais exposée au client)
ANTHROPIC_API_KEY="sk-ant-..."

# Espace admin — authentification « admin unique » (pas de table User) — voir docs/security.md
# Mot de passe de l'unique administrateur (comparaison côté serveur, en temps constant ;
# en production, stocker de préférence un hash argon2/bcrypt plutôt que le mot de passe en clair).
ADMIN_PASSWORD="change-me"
# Secret de signature du cookie de session (HMAC). Chaîne aléatoire longue, jamais commitée.
SESSION_SECRET="change-me-long-random-secret"
